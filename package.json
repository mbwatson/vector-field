{
  "name": "vector-field-simulator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "benchmark:particles": "npm run build && node tests/performance/particle-benchmark.mjs",
