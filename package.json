    "test:browser": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "vite": "^7.0.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.3.1",
    "p5": "^2.3.0"
  }
}
